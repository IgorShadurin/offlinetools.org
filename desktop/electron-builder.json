{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "org.offlinetools.app",
  "productName": "OfflineTools",
  "asar": true,
  "directories": {
    "output": "release/${version}"
  },
  "files": [
    "dist-electron",
    "dist",
    "resources"
  ],
  "mac": {
    "artifactName": "${productName}_${arch}.${ext}",
    "icon": "resources/icons/icon.icns",
    "extendInfo": {
      "CFBundleName": "OfflineTools",
      "CFBundleDisplayName": "OfflineTools"
    },
    "target": [
      {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      },
      {
        "target": "zip",
        "arch": ["x64", "arm64"]
      }
    ],
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "entitlements": "resources/entitlements.mac.plist",
    "entitlementsInherit": "resources/entitlements.mac.plist"
  },
  "dmg": {
    "sign": false
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "artifactName": "${productName}.${ext}",
    "icon": "resources/icons/icon_256x256.png"
  },
  "linux": {
    "icon": "resources/icons",
    "target": ["AppImage", "deb"],
    "artifactName": "${productName}_${arch}.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false
  },
  "publish": {
    "provider": "github",
    "owner": "IgorShadurin",
    "repo": "offlinetools.org"
  }
}
